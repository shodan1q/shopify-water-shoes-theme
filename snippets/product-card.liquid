{%- comment -%}
  Render product card.
  Required: product
{%- endcomment -%}

<a href="{{ product.url }}" class="product-card">
  <div class="product-card__media">
    {%- if product.compare_at_price > product.price -%}
      <span class="product-card__badge">{{ 'products.product.sale' | t | default: 'Sale' }}</span>
    {%- elsif product.tags contains 'new' -%}
      <span class="product-card__badge">New</span>
    {%- endif -%}

    {%- if product.featured_media -%}
      <img
        src="{{ product.featured_media | image_url: width: 600 }}"
        alt="{{ product.featured_media.alt | escape | default: product.title }}"
        loading="lazy"
        width="600"
        height="600">
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}

    <span class="product-card__quick-add">View product →</span>
    <button type="button" class="product-card__wishlist" data-wishlist-btn data-product-handle="{{ product.handle }}" aria-label="Save to wishlist">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    </button>
  </div>

  <div class="product-card__info">
    {%- if settings.show_vendor and product.vendor != blank -%}
      <div class="product-card__vendor">{{ product.vendor }}</div>
    {%- endif -%}
    <div class="product-card__title">{{ product.title }}</div>
    <div class="product-card__price">{% render 'price', product: product %}</div>
  </div>
</a>
