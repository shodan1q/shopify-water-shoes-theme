<section class="countdown-section"{% if section.settings.bg_color != blank %} style="background:{{ section.settings.bg_color }}; color:{{ section.settings.text_color | default: '#fff' }};"{% endif %}>
  <div class="page-width">
    <div class="countdown-inner">
      <div class="countdown-copy">
        {%- if section.settings.eyebrow != blank -%}<span class="hero-eyebrow" style="background:rgba(255,255,255,0.18); color:#fff;">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2 style="color: inherit;">{{ section.settings.heading }}</h2>
        {%- if section.settings.subtitle != blank -%}<p style="opacity:0.9;">{{ section.settings.subtitle }}</p>{%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: '#' }}" class="btn btn--white mt-4">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>

      <div class="countdown-clock" data-countdown data-target="{{ section.settings.target_date | escape }}T{{ section.settings.target_time | default: '23:59:59' }}">
        <div class="countdown-unit"><strong data-d>0</strong><span>Days</span></div>
        <div class="countdown-unit"><strong data-h>0</strong><span>Hours</span></div>
        <div class="countdown-unit"><strong data-m>0</strong><span>Minutes</span></div>
        <div class="countdown-unit"><strong data-s>0</strong><span>Seconds</span></div>
      </div>
    </div>
  </div>
</section>

<style>
  .countdown-section {
    padding: 64px 0;
    background: linear-gradient(135deg, var(--color-primary-dark), #134e4a);
    color: #fff;
    overflow: hidden;
    position: relative;
  }
  .countdown-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  @media (max-width: 800px) { .countdown-inner { grid-template-columns: 1fr; text-align: center; } }
  .countdown-copy h2 { font-size: clamp(28px, 4vw, 40px); margin-bottom: 12px; }

  .countdown-clock {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .countdown-unit {
    text-align: center;
    background: rgba(255,255,255,0.08);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border-radius: 16px;
    padding: 18px 8px;
    border: 1px solid rgba(255,255,255,0.12);
  }
  .countdown-unit strong {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 900;
    line-height: 1;
    display: block;
    margin-bottom: 6px;
    letter-spacing: -0.02em;
  }
  .countdown-unit span {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    opacity: 0.7;
    font-weight: 600;
  }
  .countdown-section[data-done] .countdown-clock { opacity: 0.4; }
</style>

<script>
(function(){
  document.querySelectorAll('[data-countdown]:not([data-init])').forEach((root) => {
    root.dataset.init = '1';
    const target = new Date(root.dataset.target).getTime();
    const d = root.querySelector('[data-d]');
    const h = root.querySelector('[data-h]');
    const m = root.querySelector('[data-m]');
    const s = root.querySelector('[data-s]');
    function tick() {
      const now = Date.now();
      let diff = Math.max(0, target - now);
      if (diff === 0) { root.closest('.countdown-section')?.setAttribute('data-done', ''); }
      const days = Math.floor(diff / 86400000); diff -= days * 86400000;
      const hours = Math.floor(diff / 3600000); diff -= hours * 3600000;
      const mins = Math.floor(diff / 60000); diff -= mins * 60000;
      const secs = Math.floor(diff / 1000);
      d.textContent = days;
      h.textContent = String(hours).padStart(2, '0');
      m.textContent = String(mins).padStart(2, '0');
      s.textContent = String(secs).padStart(2, '0');
    }
    tick();
    setInterval(tick, 1000);
  });
})();
</script>

{% schema %}
{
  "name": "Countdown",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Drop incoming" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Summer collection — launching soon" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "First 500 customers get a free travel pouch with their order." },
    { "type": "text", "id": "target_date", "label": "Target date (YYYY-MM-DD)", "info": "Example: 2026-07-01" },
    { "type": "text", "id": "target_time", "label": "Target time (HH:MM:SS)", "default": "23:59:59" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Notify me" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "color", "id": "bg_color", "label": "Background" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" }
  ],
  "presets": [ { "name": "Countdown" } ]
}
{% endschema %}
