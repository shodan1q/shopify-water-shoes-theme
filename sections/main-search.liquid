<section class="search-page">
  <div class="page-width">
    <h1 class="text-center mb-8">{{ 'templates.search.title' | t }}</h1>
    <form action="{{ routes.search_url }}" method="get" class="search-form" role="search">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}" required>
      <button type="submit" class="btn">{{ 'general.search.search' | t }}</button>
    </form>

    {%- if search.performed -%}
      <p class="text-center mb-8">{{ 'general.search.results_with_count' | t: count: search.results_count }}</p>
      {%- if search.results.size > 0 -%}
        <div class="product-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'product-card', product: item %}
            {%- else -%}
              <a href="{{ item.url }}" class="product-card">
                <div class="product-card__info">
                  <div class="product-card__title">{{ item.title }}</div>
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <p class="text-center">{{ 'general.search.no_results' | t }}</p>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Search",
  "settings": []
}
{% endschema %}
