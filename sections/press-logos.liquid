<section class="press-section"{% if section.settings.bg_color != blank %} style="background:{{ section.settings.bg_color }}"{% endif %}>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <p class="press-heading">{{ section.settings.heading }}</p>
    {%- endif -%}

    <div class="press-logos {% if section.settings.scroll %}press-logos--scroll{% endif %}">
      <div class="press-logos__track">
        {%- for block in section.blocks -%}
          {%- assign logo = block -%}
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="press-logo" {{ block.shopify_attributes }} target="_blank" rel="noopener">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 320 }}" alt="{{ block.settings.name | escape }}" loading="lazy" width="160" height="40">
              {%- else -%}
                <span>{{ block.settings.name }}</span>
              {%- endif -%}
            </a>
          {%- else -%}
            <div class="press-logo" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 320 }}" alt="{{ block.settings.name | escape }}" loading="lazy" width="160" height="40">
              {%- else -%}
                <span>{{ block.settings.name }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- if section.settings.scroll -%}
          {%- comment -%} duplicate for infinite scroll {%- endcomment -%}
          {%- for block in section.blocks -%}
            <div class="press-logo" aria-hidden="true">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 320 }}" alt="" loading="lazy" width="160" height="40">
              {%- else -%}
                <span>{{ block.settings.name }}</span>
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .press-section {
    padding: 56px 0;
    background: var(--bg, #fff);
    border-block: 1px solid var(--color-border);
  }
  .press-heading {
    text-align: center;
    margin-bottom: 32px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #94a3b8;
  }
  .press-logos {
    overflow: hidden;
  }
  .press-logos__track {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
    flex-wrap: wrap;
  }
  .press-logos--scroll .press-logos__track {
    flex-wrap: nowrap;
    width: max-content;
    animation: scroll-x 30s linear infinite;
  }
  @keyframes scroll-x {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .press-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    flex-shrink: 0;
    opacity: 0.55;
    transition: opacity 0.2s, filter 0.2s;
    filter: grayscale(100%);
  }
  .press-logo:hover { opacity: 1; filter: grayscale(0); }
  .press-logo img { max-height: 36px; width: auto; object-fit: contain; }
  .press-logo span {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #475569;
  }
</style>

{% schema %}
{
  "name": "Press logos",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "As featured in"
    },
    {
      "type": "checkbox",
      "id": "scroll",
      "label": "Auto-scroll (marquee)",
      "default": false
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background"
    }
  ],
  "max_blocks": 12,
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Outside"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image (recommended)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Press logos",
      "blocks": [
        {
          "type": "logo",
          "settings": {
            "name": "Outside"
          }
        },
        {
          "type": "logo",
          "settings": {
            "name": "Surfer"
          }
        },
        {
          "type": "logo",
          "settings": {
            "name": "GearJunkie"
          }
        },
        {
          "type": "logo",
          "settings": {
            "name": "Travel + Leisure"
          }
        },
        {
          "type": "logo",
          "settings": {
            "name": "Runner's World"
          }
        }
      ]
    }
  ]
}
{% endschema %}
