<section class="section-padding collage-section"{% if section.settings.bg_color != blank %} style="background:{{ section.settings.bg_color }}"{% endif %}>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-heading">
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="collage">
      {%- for block in section.blocks limit: 5 -%}
        {%- assign idx = forloop.index -%}
        {%- capture tile_inner -%}
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.heading | escape }}" loading="lazy">
          {%- else -%}
            <div style="height:100%;background:linear-gradient(135deg,#ccfbf1,#5eead4);"></div>
          {%- endif -%}
          {%- if block.settings.heading != blank or block.settings.subheading != blank -%}
            <div class="collage-tile__caption">
              {%- if block.settings.heading != blank -%}<strong>{{ block.settings.heading }}</strong>{%- endif -%}
              {%- if block.settings.subheading != blank -%}<span>{{ block.settings.subheading }}</span>{%- endif -%}
            </div>
          {%- endif -%}
        {%- endcapture -%}
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" class="collage-tile collage-tile--{{ idx }}" {{ block.shopify_attributes }}>{{ tile_inner }}</a>
        {%- else -%}
          <div class="collage-tile collage-tile--{{ idx }}" {{ block.shopify_attributes }}>{{ tile_inner }}</div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .collage {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, minmax(180px, 280px));
    gap: 16px;
  }
  .collage-tile {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    isolation: isolate;
    background: #f1f5f9;
    transition: transform 0.4s;
  }
  .collage-tile:hover { transform: scale(1.01); }
  .collage-tile--1 { grid-column: span 2; grid-row: span 2; }
  .collage-tile img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s; }
  .collage-tile:hover img { transform: scale(1.06); }
  .collage-tile::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 50%, rgba(15,23,42,0.55)); }
  .collage-tile__caption {
    position: absolute;
    inset: auto 0 0 0;
    padding: 20px;
    color: #fff;
    z-index: 1;
  }
  .collage-tile__caption strong { display: block; font-size: 17px; font-family: var(--font-heading); }
  .collage-tile__caption span { font-size: 13px; opacity: 0.85; }
  @media (max-width: 900px) {
    .collage { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
    .collage-tile--1 { grid-column: span 2; }
  }
</style>

{% schema %}
{
  "name": "Collage",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "color", "id": "bg_color", "label": "Background" }
  ],
  "max_blocks": 5,
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "text", "id": "subheading", "label": "Subheading" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "tile", "settings": { "heading": "Best sellers", "subheading": "Shop now" } },
      { "type": "tile", "settings": { "heading": "Kids", "subheading": "Family kit" } },
      { "type": "tile", "settings": { "heading": "Sale", "subheading": "Up to 30% off" } },
      { "type": "tile", "settings": { "heading": "New arrivals", "subheading": "2025 collection" } },
      { "type": "tile", "settings": { "heading": "Gift cards", "subheading": "From $25" } }
    ]
  },
  "presets": [ { "name": "Collage" } ]
}
{% endschema %}
