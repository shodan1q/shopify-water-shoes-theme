<section class="section-padding"{% if section.settings.bg_color != blank %} style="background:{{ section.settings.bg_color }}"{% endif %}>
  <div class="page-width">
    <div class="section-heading">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}<p>{{ section.settings.subtitle }}</p>{%- endif -%}
    </div>

    <div class="collection-list" style="--cols:{{ section.settings.columns }};">
      {%- for block in section.blocks -%}
        {%- assign coll = collections[block.settings.collection] -%}
        {%- if coll == empty or coll == nil -%}{%- continue -%}{%- endif -%}
        <a href="{{ coll.url }}" class="collection-card" {{ block.shopify_attributes }}>
          <div class="collection-card__media">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 1000 }}" alt="{{ coll.title }}" loading="lazy">
            {%- elsif coll.image -%}
              <img src="{{ coll.image | image_url: width: 1000 }}" alt="{{ coll.title }}" loading="lazy">
            {%- elsif coll.products.first.featured_media -%}
              <img src="{{ coll.products.first.featured_media | image_url: width: 1000 }}" alt="{{ coll.title }}" loading="lazy">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="collection-card__body">
            <h3>{{ block.settings.heading_override | default: coll.title }}</h3>
            <span class="collection-card__cta">Shop now →</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .collection-list {
    display: grid;
    grid-template-columns: repeat(var(--cols, 3), minmax(0, 1fr));
    gap: 24px;
  }
  @media (max-width: 900px) { .collection-list { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 540px) { .collection-list { grid-template-columns: 1fr; } }

  .collection-card {
    position: relative;
    display: block;
    aspect-ratio: 4/5;
    border-radius: 20px;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(.2,.8,.2,1);
    isolation: isolate;
  }
  .collection-card:hover { transform: translateY(-6px); }
  .collection-card__media { position: absolute; inset: 0; }
  .collection-card__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s ease; }
  .collection-card:hover .collection-card__media img { transform: scale(1.08); }
  .collection-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 30%, rgba(15, 23, 42, 0.7));
  }
  .collection-card__body {
    position: absolute;
    inset: auto 0 0 0;
    padding: 24px;
    color: #fff;
    z-index: 1;
  }
  .collection-card__body h3 { color: #fff; font-size: clamp(20px, 2.2vw, 26px); margin-bottom: 4px; }
  .collection-card__cta { font-size: 13px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; }
</style>

{% schema %}
{
  "name": "Collection list",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your fit" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "color", "id": "bg_color", "label": "Background" }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image (overrides collection image)" },
        { "type": "text", "id": "heading_override", "label": "Heading override" }
      ]
    }
  ],
  "presets": [ { "name": "Collection list", "blocks": [ { "type": "collection" }, { "type": "collection" }, { "type": "collection" } ] } ]
}
{% endschema %}
