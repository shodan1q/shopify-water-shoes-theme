<section class="wave-trust" style="background:{{ section.settings.bg_color }};color:{{ section.settings.text_color }}">
  <div class="page-width wave-trust__inner">
    {%- for block in section.blocks -%}
      <div class="wave-trust__item" {{ block.shopify_attributes }}>
        {%- case block.settings.icon -%}
          {%- when 'refund' -%}
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
          {%- when 'support' -%}
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          {%- when 'secure' -%}
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          {%- when 'shipping' -%}
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          {%- when 'leaf' -%}
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96c1.4 9.3 -2.3 14.3 -8.2 17z"/><path d="M2 21c0 -3 1.85 -5.36 5.08 -6"/></svg>
          {%- else -%}
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        {%- endcase -%}
        <span class="wave-trust__text">{{ block.settings.text }}</span>
      </div>
    {%- endfor -%}
  </div>

  <svg class="wave-trust__edge" viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0,0 C240,60 480,60 720,30 C960,0 1200,0 1440,30 L1440,60 L0,60 Z" fill="{{ settings.color_background }}"/>
  </svg>
</section>

<style>
  .wave-trust { position: relative; padding: 18px 0 56px; }
  .wave-trust__inner {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
    gap: 24px;
    align-items: center;
    text-align: center;
  }
  .wave-trust__item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.2px;
  }
  .wave-trust__text { white-space: nowrap; }
  .wave-trust__edge {
    position: absolute;
    bottom: -1px; left: 0; right: 0;
    width: 100%;
    height: 60px;
    display: block;
  }
  @media (max-width: 768px) {
    .wave-trust { padding: 14px 0 44px; }
    .wave-trust__inner { grid-template-columns: 1fr; gap: 8px; }
    .wave-trust__item { font-size: 13px; gap: 10px; }
    .wave-trust__item svg { width: 22px; height: 22px; }
    .wave-trust__edge { height: 36px; }
  }
</style>

{% schema %}
{
  "name": "Wave trust bar",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#2DD4BF" },
    { "type": "color", "id": "text_color", "label": "Text & icon color", "default": "#FFFFFF" }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "refund", "label": "Refund / arrow" },
            { "value": "support", "label": "Support / chat" },
            { "value": "secure", "label": "Secure / lock" },
            { "value": "shipping", "label": "Shipping / truck" },
            { "value": "leaf", "label": "Eco / leaf" },
            { "value": "check", "label": "Check" }
          ],
          "default": "refund"
        },
        { "type": "text", "id": "text", "label": "Text", "default": "Satisfied or refunded" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "item", "settings": { "icon": "refund", "text": "Satisfied or refunded" } },
      { "type": "item", "settings": { "icon": "support", "text": "Responsive support" } },
      { "type": "item", "settings": { "icon": "secure", "text": "Secure payments" } }
    ]
  },
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
