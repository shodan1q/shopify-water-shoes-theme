<section class="section-padding multicolumn"{% if section.settings.bg_color != blank %} style="background:{{ section.settings.bg_color }}"{% endif %}>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-heading">
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.subtitle != blank -%}<p>{{ section.settings.subtitle }}</p>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="multicolumn-grid" style="--columns: {{ section.settings.columns }};">
      {%- for block in section.blocks -%}
        <div class="multicolumn-item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="multicolumn-item__media">
              <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.heading | escape }}" loading="lazy">
            </div>
          {%- elsif block.settings.icon != blank -%}
            <div class="multicolumn-item__icon">{{ block.settings.icon }}</div>
          {%- endif -%}
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
          {%- if block.settings.link_label != blank -%}
            <a href="{{ block.settings.link | default: '#' }}" class="multicolumn-item__link">{{ block.settings.link_label }} →</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .multicolumn-grid {
    display: grid;
    grid-template-columns: repeat(var(--columns, 3), minmax(0, 1fr));
    gap: 32px;
  }
  @media (max-width: 900px) { .multicolumn-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 540px) { .multicolumn-grid { grid-template-columns: 1fr; } }
  .multicolumn-item { text-align: center; }
  .multicolumn-item__media {
    aspect-ratio: 1;
    border-radius: 20px;
    overflow: hidden;
    margin-bottom: 18px;
    background: #f1f5f9;
  }
  .multicolumn-item__media img { width: 100%; height: 100%; object-fit: cover; }
  .multicolumn-item__icon {
    width: 64px; height: 64px;
    border-radius: 18px;
    background: linear-gradient(135deg, #ccfbf1, #5eead4);
    color: var(--color-primary-dark);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    margin: 0 auto 16px;
  }
  .multicolumn-item h3 { font-size: 18px; margin-bottom: 8px; }
  .multicolumn-item p { color: #64748b; font-size: 14px; line-height: 1.65; }
  .multicolumn-item__link {
    display: inline-block;
    margin-top: 12px;
    font-size: 13px;
    font-weight: 700;
    color: var(--color-primary-dark);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
</style>

{% schema %}
{
  "name": "Multicolumn",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Tidefoot"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Or icon (emoji)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick-dry"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Drains and dries in minutes."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Multicolumn",
      "blocks": [
        {
          "type": "column",
          "settings": {
            "icon": "💧",
            "heading": "Quick-dry knit"
          }
        },
        {
          "type": "column",
          "settings": {
            "icon": "🦶",
            "heading": "Barefoot feel"
          }
        },
        {
          "type": "column",
          "settings": {
            "icon": "⚡",
            "heading": "Anti-slip sole"
          }
        }
      ]
    }
  ]
}
{% endschema %}
