<footer class="site-footer">
  <div class="page-width">
    <div class="footer-grid">
      <div class="footer-col">
        <h4>{{ shop.name | default: 'AquaStep' }}</h4>
        <p>{{ section.settings.about_text }}</p>
        {% render 'social-icons' %}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            <ul>
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- elsif block.type == 'text' -%}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            <p>{{ block.settings.text }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <p>{{ shop.address.country }}</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "about_text",
      "label": "About text",
      "default": "Premium water shoes engineered for performance. Lightweight, breathable, and built to grip — from beach to trail."
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text block",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Contact"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "support@aquastep.com\n+1 (555) 123-4567"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "menu",
        "settings": { "heading": "Shop", "menu": "footer" }
      },
      {
        "type": "menu",
        "settings": { "heading": "Support" }
      },
      {
        "type": "text",
        "settings": { "heading": "Contact", "text": "support@aquastep.com\nMon-Fri 9am-6pm" }
      }
    ]
  },
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}
