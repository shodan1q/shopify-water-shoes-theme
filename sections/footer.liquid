<footer class="site-footer" style="background:{{ section.settings.bg_color | default: '#0F766E' }};color:#fff;">
  <div class="page-width">
    <div class="footer-grid">
      <div class="footer-col footer-col--brand js-reveal">
        <h4 class="footer-script">{{ shop.name | default: 'Tidefoot' }}</h4>
        <p>{{ section.settings.about_text }}</p>
        {% render 'social-icons' %}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          <div class="footer-col js-reveal" {{ block.shopify_attributes }}>
            <h4 class="footer-script">{{ block.settings.heading }}</h4>
            <ul class="footer-links">
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}"><span class="footer-links__arrow">▷</span>{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- elsif block.type == 'text' -%}
          <div class="footer-col js-reveal" {{ block.shopify_attributes }}>
            <h4 class="footer-script">{{ block.settings.heading }}</h4>
            <p>{{ block.settings.text }}</p>
            {%- form 'customer', class: 'footer-newsletter' -%}
              <input type="hidden" name="contact[tags]" value="newsletter,footer">
              <input type="email" name="contact[email]" placeholder="Your email" required>
              <button type="submit" aria-label="Subscribe">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>
              {%- if form.posted_successfully? -%}
                <p class="footer-newsletter__success">Thanks for subscribing!</p>
              {%- endif -%}
            {%- endform -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>

      {%- if settings.show_country_selector and localization.available_countries.size > 1 -%}
        <div class="footer-localization">
          {%- form 'localization', class: 'footer-localization__form' -%}
            <label for="FooterCountryForm" class="visually-hidden">Country / region</label>
            <div class="footer-localization__select">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              <select name="country_code" id="FooterCountryForm" onchange="this.form.submit()">
                {%- for country in localization.available_countries -%}
                  <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
                    {{ country.name }} ({{ country.currency.iso_code }})
                  </option>
                {%- endfor -%}
              </select>
            </div>
            {%- if localization.available_languages.size > 1 -%}
              <label for="FooterLangForm" class="visually-hidden">Language</label>
              <div class="footer-localization__select">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15 15 0 0 1 4 10 15 15 0 0 1-4 10 15 15 0 0 1-4-10 15 15 0 0 1 4-10z"/></svg>
                <select name="locale_code" id="FooterLangForm" onchange="this.form.submit()">
                  {%- for lang in localization.available_languages -%}
                    <option value="{{ lang.iso_code }}" {% if lang.iso_code == localization.language.iso_code %}selected{% endif %}>{{ lang.endonym_name | capitalize }}</option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

      <div class="footer-payments" aria-label="Accepted payment methods">
        <svg viewBox="0 0 40 24" width="40" height="24" aria-label="Amex"><rect width="40" height="24" rx="4" fill="#0072CE"/><text x="20" y="16" text-anchor="middle" fill="#fff" font-size="9" font-weight="800" font-family="Arial">AMEX</text></svg>
        <svg viewBox="0 0 40 24" width="40" height="24" aria-label="Apple Pay"><rect width="40" height="24" rx="4" fill="#000"/><text x="20" y="16" text-anchor="middle" fill="#fff" font-size="8" font-weight="700" font-family="Helvetica">Pay</text></svg>
        <svg viewBox="0 0 40 24" width="40" height="24" aria-label="Mastercard"><rect width="40" height="24" rx="4" fill="#fff"/><circle cx="16" cy="12" r="7" fill="#EB001B"/><circle cx="24" cy="12" r="7" fill="#F79E1B" fill-opacity="0.9"/></svg>
        <svg viewBox="0 0 40 24" width="40" height="24" aria-label="PayPal"><rect width="40" height="24" rx="4" fill="#fff"/><text x="20" y="16" text-anchor="middle" fill="#003087" font-size="9" font-weight="800" font-family="Arial" font-style="italic">PayPal</text></svg>
        <svg viewBox="0 0 40 24" width="40" height="24" aria-label="Visa"><rect width="40" height="24" rx="4" fill="#fff"/><text x="20" y="16" text-anchor="middle" fill="#1A1F71" font-size="10" font-weight="900" font-family="Arial" font-style="italic" letter-spacing="0.5">VISA</text></svg>
      </div>
    </div>
  </div>

  <button type="button" class="back-to-top" data-back-to-top aria-label="Back to top" hidden>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0F766E" },
    {
      "type": "textarea",
      "id": "about_text",
      "label": "About text",
      "default": "Tidefoot — premium water shoes engineered for performance. Quick-dry knit, reef-grade rubber, built to grip from sunrise paddles to canyon hikes."
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    },
    {
      "type": "text",
      "name": "Text block / newsletter",
      "limit": 2,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Stay tuned" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Promotions, new products and sales — straight to your inbox." }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}
