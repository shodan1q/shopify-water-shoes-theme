<section class="image-banner image-banner--{{ section.settings.height }}">
  {%- if section.settings.image != blank -%}
    <img
      src="{{ section.settings.image | image_url: width: 2400 }}"
      srcset="{{ section.settings.image | image_url: width: 1200 }} 1200w,
              {{ section.settings.image | image_url: width: 1800 }} 1800w,
              {{ section.settings.image | image_url: width: 2400 }} 2400w"
      sizes="100vw"
      alt="{{ section.settings.heading | escape }}"
      loading="lazy"
      class="image-banner__image">
  {%- else -%}
    <div class="image-banner__placeholder"></div>
  {%- endif -%}

  <div class="image-banner__overlay" style="background: linear-gradient({{ section.settings.overlay_dir }}, rgba(15,23,42,{{ section.settings.overlay_opacity | divided_by: 100.0 }}), rgba(15,23,42,0));"></div>

  <div class="image-banner__content image-banner__content--{{ section.settings.text_position }}">
    <div class="page-width">
      <div class="image-banner__inner">
        {%- if section.settings.eyebrow != blank -%}<span class="hero-eyebrow" style="background:rgba(255,255,255,0.18); color:#fff;">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.text != blank -%}<p>{{ section.settings.text }}</p>{%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: '#' }}" class="btn btn--large">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .image-banner { position: relative; overflow: hidden; isolation: isolate; }
  .image-banner--small { min-height: 380px; }
  .image-banner--medium { min-height: 540px; }
  .image-banner--large { min-height: 70vh; }
  .image-banner__image, .image-banner__placeholder, .image-banner__overlay { position: absolute; inset: 0; }
  .image-banner__image { width: 100%; height: 100%; object-fit: cover; z-index: -2; }
  .image-banner__placeholder { background: linear-gradient(135deg, #ccfbf1, #5eead4); z-index: -2; }
  .image-banner__overlay { z-index: -1; }
  .image-banner__content {
    position: relative;
    display: flex;
    align-items: center;
    min-height: inherit;
    padding: 80px 0;
    color: #fff;
  }
  .image-banner--small .image-banner__content { min-height: 380px; }
  .image-banner--medium .image-banner__content { min-height: 540px; }
  .image-banner--large .image-banner__content { min-height: 70vh; }
  .image-banner__inner { max-width: 600px; }
  .image-banner__content--left .image-banner__inner { margin-right: auto; }
  .image-banner__content--center .image-banner__inner { margin: 0 auto; text-align: center; }
  .image-banner__content--right .image-banner__inner { margin-left: auto; text-align: right; }
  .image-banner h2 { color: #fff; font-size: clamp(28px, 5vw, 52px); margin-bottom: 16px; }
  .image-banner p { font-size: 17px; color: rgba(255,255,255,0.92); margin-bottom: 28px; }
</style>

{% schema %}
{
  "name": "Image banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Beach to boardroom" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "One shoe, every surface." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    {
      "type": "select",
      "id": "height",
      "label": "Banner height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "overlay_dir",
      "label": "Overlay direction",
      "options": [
        { "value": "to right", "label": "From left" },
        { "value": "to left", "label": "From right" },
        { "value": "to top", "label": "From bottom" }
      ],
      "default": "to right"
    },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity (%)", "min": 0, "max": 80, "step": 5, "default": 45 }
  ],
  "presets": [ { "name": "Image banner" } ]
}
{% endschema %}
