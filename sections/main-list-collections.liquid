<section class="collection-header">
  <div class="page-width">
    <h1>Collections</h1>
    <p>Browse all of our water shoe collections.</p>
  </div>
</section>

<section class="collection-body">
  <div class="page-width">
    <div class="product-grid">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="product-card">
          <div class="product-card__media">
            {%- if collection.image -%}
              <img src="{{ collection.image | image_url: width: 600 }}" alt="{{ collection.image.alt | escape | default: collection.title }}" loading="lazy">
            {%- elsif collection.products.first.featured_media -%}
              <img src="{{ collection.products.first.featured_media | image_url: width: 600 }}" alt="{{ collection.title }}" loading="lazy">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="product-card__info">
            <div class="product-card__title">{{ collection.title }}</div>
            <div class="product-card__price">{{ collection.products_count }} products</div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collections list",
  "settings": []
}
{% endschema %}
