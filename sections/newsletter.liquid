<section class="section-padding">
  <div class="page-width">
    <div class="newsletter">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow" style="color:rgba(255,255,255,0.8);font-weight:700;letter-spacing:2px;text-transform:uppercase;font-size:13px;display:block;margin-bottom:12px;">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
      {% form 'customer', class: 'newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" id="NewsletterForm--{{ section.id }}" placeholder="{{ 'general.newsletter_form.email_placeholder' | t }}" required>
        <button type="submit" name="commit">{{ section.settings.button_label }}</button>
        {%- if form.posted_successfully? -%}
          <p style="color:#fff;width:100%;margin-top:16px;">{{ 'general.newsletter_form.confirmation' | t }}</p>
        {%- endif -%}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Join the wave"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get 10% off your first order"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Subscribe for early access to new colors, exclusive drops, and adventure stories from our crew."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    }
  ],
  "presets": [
    { "name": "Newsletter" }
  ]
}
{% endschema %}
