<section class="video-section section-padding"{% if section.settings.bg_color != blank %} style="background:{{ section.settings.bg_color }}"{% endif %}>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-heading">
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.subtitle != blank -%}<p>{{ section.settings.subtitle }}</p>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="video-wrap" data-video-wrap>
      {%- if section.settings.video != blank -%}
        {%- assign video = section.settings.video -%}
        {%- if section.settings.cover != blank -%}
          <button type="button" class="video-cover" data-video-play aria-label="Play video">
            <img src="{{ section.settings.cover | image_url: width: 1600 }}" alt="{{ section.settings.heading | escape }}" loading="lazy">
            <span class="video-play-button" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            </span>
          </button>
        {%- endif -%}
        <video class="video-element" data-video-el {% if section.settings.cover == blank %}autoplay{% endif %} loop muted playsinline preload="metadata">
          {%- for source in video.sources -%}
            <source src="{{ source.url }}" type="{{ source.mime_type }}">
          {%- endfor -%}
        </video>
      {%- elsif section.settings.video_url != blank -%}
        <div class="video-embed">
          {%- if section.settings.video_url.type == 'youtube' -%}
            <iframe src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?rel=0&modestbranding=1" loading="lazy" allow="autoplay; encrypted-media" allowfullscreen></iframe>
          {%- elsif section.settings.video_url.type == 'vimeo' -%}
            <iframe src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}" loading="lazy" allow="autoplay; fullscreen" allowfullscreen></iframe>
          {%- endif -%}
        </div>
      {%- else -%}
        <div class="video-placeholder">▶ Add a video in the editor</div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .video-wrap {
    position: relative;
    aspect-ratio: 16/9;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 40px 80px -24px rgba(15, 23, 42, 0.35);
    background: #0f172a;
  }
  .video-cover { position: absolute; inset: 0; cursor: pointer; padding: 0; border: 0; width: 100%; height: 100%; }
  .video-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .video-cover::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.4)); }
  .video-play-button {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 80px; height: 80px;
    border-radius: 50%;
    background: rgba(255,255,255,0.95);
    color: var(--color-primary-dark);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    transition: transform 0.2s, background 0.2s;
    z-index: 2;
  }
  .video-cover:hover .video-play-button { transform: translate(-50%, -50%) scale(1.1); background: #fff; }
  .video-element { width: 100%; height: 100%; object-fit: cover; display: block; }
  .video-embed, .video-embed iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  .video-placeholder { color: rgba(255,255,255,0.6); display: flex; align-items: center; justify-content: center; height: 100%; font-size: 18px; }
  .video-cover[hidden] { display: none; }
</style>

<script>
(function(){
  const wrap = document.currentScript.previousElementSibling;
  const root = document.querySelector('[data-video-wrap]:not([data-init])');
  if (!root) return;
  root.setAttribute('data-init', '1');
  const btn = root.querySelector('[data-video-play]');
  const vid = root.querySelector('[data-video-el]');
  if (btn && vid) {
    btn.addEventListener('click', () => {
      btn.hidden = true;
      vid.controls = true;
      vid.play();
    });
  }
})();
</script>

{% schema %}
{
  "name": "Video",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Watch the splash" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "See Tidefoot in action" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "From morning surf checks to canyon hikes — one shoe, every surface." },
    { "type": "video", "id": "video", "label": "Video (Shopify-hosted)" },
    { "type": "video_url", "id": "video_url", "label": "External video URL", "accept": ["youtube", "vimeo"] },
    { "type": "image_picker", "id": "cover", "label": "Cover image (recommended)" },
    { "type": "color", "id": "bg_color", "label": "Background" }
  ],
  "presets": [ { "name": "Video" } ]
}
{% endschema %}
