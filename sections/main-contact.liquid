<section class="contact-page">
  <div class="page-width">
    {% render 'breadcrumb' %}

    <header class="section-heading" style="margin-bottom:48px">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h1>{{ page.title | default: section.settings.heading }}</h1>
      {%- if section.settings.subtitle != blank -%}
        <p>{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </header>

    <div class="contact-layout">
      <div class="contact-info">
        <div class="contact-card">
          <div class="contact-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <h3>Email us</h3>
          <p><a href="mailto:{{ section.settings.email | default: 'support@firstt.com' }}">{{ section.settings.email | default: 'support@firstt.com' }}</a></p>
          <span>Replies within 1 business day</span>
        </div>

        <div class="contact-card">
          <div class="contact-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3>Support hours</h3>
          <p>{{ section.settings.hours | default: 'Monday – Friday' }}</p>
          <span>{{ section.settings.timezone | default: '9am – 6pm PST' }}</span>
        </div>

        {%- if section.settings.phone != blank -%}
          <div class="contact-card">
            <div class="contact-card__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <h3>Phone</h3>
            <p><a href="tel:{{ section.settings.phone | replace: ' ', '' }}">{{ section.settings.phone }}</a></p>
            <span>Toll-free in the US</span>
          </div>
        {%- endif -%}

        <div class="contact-quick">
          <h4>Quick answers</h4>
          <ul>
            <li><a href="/pages/faq">📦 Shipping &amp; returns</a></li>
            <li><a href="/pages/size-guide">📏 Size guide</a></li>
            <li><a href="/pages/care">🧼 Care instructions</a></li>
            <li><a href="{{ routes.account_login_url }}">👤 Account help</a></li>
          </ul>
        </div>
      </div>

      <div class="contact-form-wrap">
        {%- if page.content != blank -%}
          <div class="rte mb-8">{{ page.content }}</div>
        {%- endif -%}

        {%- form 'contact', class: 'contact-form' -%}
          {%- if form.posted_successfully? -%}
            <div class="auth-alert auth-alert--success">{{ 'templates.contact.form.post_success' | t }}</div>
          {%- endif -%}
          {%- if form.errors -%}
            <div class="auth-alert auth-alert--error">{{ form.errors | default_errors }}</div>
          {%- endif -%}

          <div class="auth-row">
            <label class="auth-field"><span>{{ 'templates.contact.form.name' | t }}</span><input type="text" name="contact[name]" required></label>
            <label class="auth-field"><span>{{ 'templates.contact.form.email' | t }}</span><input type="email" name="contact[email]" required></label>
          </div>

          <label class="auth-field"><span>{{ 'templates.contact.form.phone' | t }} (optional)</span><input type="tel" name="contact[phone]"></label>

          <label class="auth-field"><span>Subject</span>
            <select name="contact[subject]">
              <option>General inquiry</option>
              <option>Order status</option>
              <option>Returns &amp; exchanges</option>
              <option>Wholesale / partnerships</option>
              <option>Press</option>
            </select>
          </label>

          <label class="auth-field"><span>{{ 'templates.contact.form.message' | t }}</span><textarea name="contact[body]" rows="6" required></textarea></label>

          <button type="submit" class="btn btn--large">{{ 'templates.contact.form.send' | t }}</button>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact form",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "We'd love to hear from you" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Contact us" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Questions about sizing, orders, or returns? Our crew replies within one business day." },
    { "type": "text", "id": "email", "label": "Support email", "default": "support@firstt.com" },
    { "type": "text", "id": "phone", "label": "Phone number" },
    { "type": "text", "id": "hours", "label": "Support hours", "default": "Monday – Friday" },
    { "type": "text", "id": "timezone", "label": "Timezone label", "default": "9am – 6pm PST" }
  ]
}
{% endschema %}
