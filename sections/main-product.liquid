<section class="product-page">
  <div class="page-width">
    <div class="product-layout">
      <div class="product-gallery" data-product-gallery>
        <div class="product-gallery__main" data-gallery-main>
          {%- if product.featured_media -%}
            <img src="{{ product.featured_media | image_url: width: 1200 }}" alt="{{ product.featured_media.alt | escape | default: product.title }}" width="1200" height="1200">
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        {%- if product.media.size > 1 -%}
          <div class="product-gallery__thumbs">
            {%- for media in product.media -%}
              <div class="product-gallery__thumb {% if forloop.first %}active{% endif %}"
                   data-gallery-thumb
                   data-src="{{ media | image_url: width: 1200 }}"
                   data-alt="{{ media.alt | escape }}">
                <img src="{{ media | image_url: width: 160 }}" alt="{{ media.alt | escape }}" width="160" height="160" loading="lazy">
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="product-info">
        {%- if settings.show_vendor and product.vendor != blank -%}
          <div class="product-info__vendor">{{ product.vendor }}</div>
        {%- endif -%}
        <h1 class="product-info__title">{{ product.title }}</h1>

        <div class="product-info__price" data-product-price>
          {% render 'price', product: product %}
        </div>

        {%- if product.description != blank -%}
          <div class="product-info__description rte">{{ product.description }}</div>
        {%- endif -%}

        {%- form 'product', product, data-product-form: '', id: 'ProductForm' -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

          <div class="product-form__options">
            {%- unless product.has_only_default_variant -%}
              {%- for option in product.options_with_values -%}
                <div class="product-form__option">
                  <label class="product-form__label">{{ option.name }}: <span data-selected-value>{{ option.selected_value }}</span></label>
                  <div class="product-form__values">
                    {%- for value in option.values -%}
                      {%- assign input_id = section.id | append: '-' | append: option.position | append: '-' | append: forloop.index -%}
                      <input
                        type="radio"
                        id="{{ input_id }}"
                        name="options[{{ option.name | escape }}]"
                        value="{{ value | escape }}"
                        data-option-name="{{ option.name | escape }}"
                        {% if option.selected_value == value %}checked{% endif %}>
                      <label for="{{ input_id }}">{{ value }}</label>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            {%- endunless -%}

            <div class="product-form__option">
              <label class="product-form__label" for="Quantity-{{ section.id }}">Quantity</label>
              <div class="product-quantity">
                <button type="button" data-action="minus" aria-label="Decrease quantity">−</button>
                <input type="number" id="Quantity-{{ section.id }}" name="quantity" value="1" min="1">
                <button type="button" data-action="plus" aria-label="Increase quantity">+</button>
              </div>
            </div>
          </div>

          <div class="product-form__buttons">
            <button
              type="submit"
              name="add"
              class="btn btn--large"
              data-add-to-cart
              {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
              {%- if product.selected_or_first_available_variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </button>
          </div>

          {%- if block.settings.show_dynamic_checkout -%}
            {{ form | payment_button }}
          {%- endif -%}
        {%- endform -%}

        <div class="product-meta">
          {%- if product.type != blank -%}
            <div class="product-meta__row"><strong>Type:</strong> <span>{{ product.type }}</span></div>
          {%- endif -%}
          {%- if product.tags.size > 0 -%}
            <div class="product-meta__row"><strong>Tags:</strong> <span>{{ product.tags | join: ', ' }}</span></div>
          {%- endif -%}
          <div class="product-meta__row"><strong>SKU:</strong> <span>{{ product.selected_or_first_available_variant.sku | default: 'N/A' }}</span></div>
        </div>
      </div>
    </div>
  </div>

  <script type="application/json" data-product-variants>
    [
      {%- for variant in product.variants -%}
        {
          "id": {{ variant.id }},
          "title": {{ variant.title | json }},
          "available": {{ variant.available }},
          "price": {{ variant.price }},
          "compare_at_price": {{ variant.compare_at_price | default: 'null' }},
          "options": {{ variant.options | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  </script>
</section>

{% schema %}
{
  "name": "Product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "default": true
    }
  ],
  "blocks": []
}
{% endschema %}
