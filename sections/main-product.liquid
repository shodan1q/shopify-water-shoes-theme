{%- assign current_variant = product.selected_or_first_available_variant -%}

<section class="product-page">
  <div class="page-width">
    {% render 'breadcrumb' %}

    <div class="product-layout">
      <div class="product-gallery" data-product-gallery>
        <div class="product-gallery__main" data-gallery-main data-zoomable>
          {%- if product.featured_media -%}
            <img src="{{ product.featured_media | image_url: width: 1400 }}"
                 srcset="{{ product.featured_media | image_url: width: 600 }} 600w,
                         {{ product.featured_media | image_url: width: 1000 }} 1000w,
                         {{ product.featured_media | image_url: width: 1400 }} 1400w"
                 sizes="(min-width: 900px) 600px, 100vw"
                 alt="{{ product.featured_media.alt | escape | default: product.title }}"
                 width="1400" height="1400">
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <button type="button" class="product-gallery__zoom" data-zoom-trigger aria-label="Zoom image">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          </button>
          <button type="button" class="product-gallery__wishlist" data-wishlist-btn data-product-handle="{{ product.handle }}" aria-label="Save to wishlist">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
        </div>
        {%- if product.media.size > 1 -%}
          <div class="product-gallery__thumbs">
            {%- for media in product.media -%}
              <div class="product-gallery__thumb {% if forloop.first %}active{% endif %}"
                   data-gallery-thumb
                   data-src="{{ media | image_url: width: 1400 }}"
                   data-alt="{{ media.alt | escape }}">
                <img src="{{ media | image_url: width: 160 }}" alt="{{ media.alt | escape }}" width="160" height="160" loading="lazy">
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="product-info">
        {%- if settings.show_vendor and product.vendor != blank -%}
          <a href="{{ product.vendor | url_for_vendor }}" class="product-info__vendor">{{ product.vendor }}</a>
        {%- endif -%}
        <h1 class="product-info__title">{{ product.title }}</h1>

        <div class="product-info__rating">
          <span class="stars">★★★★★</span>
          <a href="#reviews">4.8 · 523 reviews</a>
        </div>

        <div class="product-info__price" data-product-price>
          {% render 'price', product: product %}
        </div>

        {%- if product.compare_at_price > product.price -%}
          {%- assign savings = product.compare_at_price | minus: product.price -%}
          <div class="product-info__savings">
            Save {{ savings | money }}
            ({{ savings | times: 100.0 | divided_by: product.compare_at_price | round }}% off)
          </div>
        {%- endif -%}

        {%- if product.description != blank -%}
          <div class="product-info__description">{{ product.description | truncatewords: 50, '… ' }} <a href="#description">Read more</a></div>
        {%- endif -%}

        <ul class="product-benefits" aria-label="Key benefits">
          <li><span>👣</span><strong>Comfortable</strong><span>Barefoot feel, all day</span></li>
          <li><span>🚀</span><strong>Mobility</strong><span>180 g — moves with you</span></li>
          <li><span>🤳</span><strong>Stylish</strong><span>Compliments wherever you go</span></li>
        </ul>

        {%- form 'product', product, data-product-form: '', id: 'ProductForm' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          <div class="product-form__options">
            {%- unless product.has_only_default_variant -%}
              {%- for option in product.options_with_values -%}
                <div class="product-form__option">
                  <label class="product-form__label">
                    {{ option.name }}: <span data-selected-value>{{ option.selected_value }}</span>
                    {%- if option.name == 'Size' or option.name == 'size' -%}
                      <button type="button" class="size-guide-link" data-size-guide-open>Size guide</button>
                    {%- endif -%}
                  </label>
                  <div class="product-form__values">
                    {%- for value in option.values -%}
                      {%- assign input_id = section.id | append: '-' | append: option.position | append: '-' | append: forloop.index -%}
                      <input
                        type="radio"
                        id="{{ input_id }}"
                        name="options[{{ option.name | escape }}]"
                        value="{{ value | escape }}"
                        data-option-name="{{ option.name | escape }}"
                        {% if option.selected_value == value %}checked{% endif %}>
                      <label for="{{ input_id }}">{{ value }}</label>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            {%- endunless -%}

            <div class="product-form__option">
              <label class="product-form__label" for="Quantity-{{ section.id }}">Quantity</label>
              <div class="product-quantity">
                <button type="button" data-action="minus" aria-label="Decrease quantity">−</button>
                <input type="number" id="Quantity-{{ section.id }}" name="quantity" value="1" min="1">
                <button type="button" data-action="plus" aria-label="Increase quantity">+</button>
              </div>
            </div>
          </div>

          {%- if current_variant.inventory_management == 'shopify' and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= 10 -%}
            <div class="product-urgency" data-product-urgency>
              <span class="product-urgency__dot"></span>
              Only <strong>{{ current_variant.inventory_quantity }}</strong> left in stock — order soon
            </div>
          {%- endif -%}

          <div class="product-form__buttons">
            <button
              type="submit"
              name="add"
              class="btn btn--large"
              data-add-to-cart
              {% unless current_variant.available %}disabled{% endunless %}>
              {%- if current_variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </button>
          </div>

          {%- if section.settings.show_dynamic_checkout -%}
            {{ form | payment_button }}
          {%- endif -%}

          {%- assign now = 'now' | date: '%s' | times: 1 -%}
          {%- assign min_days = 86400 | times: 5 -%}
          {%- assign max_days = 86400 | times: 10 -%}
          {%- assign min_ts = now | plus: min_days -%}
          {%- assign max_ts = now | plus: max_days -%}
          <ul class="product-promises">
            <li>
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span><strong>FREE SHIPPING</strong></span>
            </li>
            <li>
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
              <span><strong>EXCLUSIVELY ONLINE</strong></span>
            </li>
            <li>
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/><path d="M18 12a2 2 0 0 0-2 2c0 1.1.9 2 2 2h4v-4h-4z"/></svg>
              <span>AT YOUR DOOR BETWEEN <strong>{{ min_ts | date: '%-d/%m' }}</strong> AND <strong>{{ max_ts | date: '%-d/%m' }}</strong></span>
            </li>
          </ul>
        {%- endform -%}

        <div class="product-share">
          <span>Share:</span>
          <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ product.url }}&text={{ product.title | url_encode }}" target="_blank" rel="noopener" aria-label="Share on X">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ product.url }}" target="_blank" rel="noopener" aria-label="Share on Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12z"/></svg>
          </a>
          <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url }}&media={{ product.featured_media | image_url: width: 1200 | prepend: 'https:' }}&description={{ product.title | url_encode }}" target="_blank" rel="noopener" aria-label="Pin on Pinterest">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0a12 12 0 0 0-4.37 23.17c-.1-.93-.2-2.36.04-3.38.22-.92 1.4-5.83 1.4-5.83s-.36-.71-.36-1.77c0-1.66.96-2.9 2.16-2.9 1.02 0 1.51.77 1.51 1.69 0 1.03-.66 2.57-1 4-.28 1.2.6 2.18 1.78 2.18 2.14 0 3.78-2.26 3.78-5.51 0-2.88-2.07-4.9-5.03-4.9-3.43 0-5.44 2.57-5.44 5.22 0 1.04.4 2.15.9 2.75.1.12.11.23.08.35-.09.36-.28 1.2-.32 1.36-.05.22-.17.27-.4.16-1.49-.7-2.42-2.88-2.42-4.63 0-3.77 2.74-7.23 7.9-7.23 4.14 0 7.36 2.95 7.36 6.9 0 4.12-2.6 7.43-6.2 7.43-1.22 0-2.36-.63-2.75-1.38l-.74 2.85c-.27 1.04-1 2.34-1.49 3.13A12 12 0 1 0 12 0z"/></svg>
          </a>
          <button type="button" class="product-share__copy" data-copy-link data-link="{{ shop.url }}{{ product.url }}" aria-label="Copy link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            <span data-copy-feedback>Copy link</span>
          </button>
        </div>

        <div class="product-meta">
          {%- if product.type != blank -%}
            <div class="product-meta__row"><strong>Type:</strong> <span>{{ product.type }}</span></div>
          {%- endif -%}
          {%- if product.tags.size > 0 -%}
            <div class="product-meta__row"><strong>Tags:</strong> <span>{{ product.tags | join: ', ' }}</span></div>
          {%- endif -%}
          <div class="product-meta__row"><strong>SKU:</strong> <span data-product-sku>{{ current_variant.sku | default: 'N/A' }}</span></div>
        </div>
      </div>
    </div>

    {%- comment -%} ───── Product Tabs ───── {%- endcomment -%}
    <div class="product-tabs" id="description">
      <div class="product-tabs__nav" role="tablist">
        <button type="button" class="product-tabs__tab is-active" data-tab="description" role="tab">Description</button>
        <button type="button" class="product-tabs__tab" data-tab="specs" role="tab">Specs</button>
        <button type="button" class="product-tabs__tab" data-tab="shipping" role="tab">Shipping &amp; Returns</button>
        <button type="button" class="product-tabs__tab" data-tab="care" role="tab">Care</button>
      </div>

      <div class="product-tabs__panel is-active" data-tab-panel="description">
        <div class="rte rte--lead">
          {{ product.description | default: 'Flexibility, comfort and style — FirstT water shoes have everything it takes to become the star of your summer. Designed for water outings, the sleek upper and grip-anywhere sole make them ideal for walking along the waterʼs edge, climbing on rocks, snorkeling, beach volleyball, or even a casual game of racket. Molded around the foot.' }}
        </div>
      </div>

      <div class="product-tabs__panel" data-tab-panel="specs">
        <table class="spec-table">
          <tbody>
            <tr><th>Material</th><td>Quick-dry knit polyester upper, TPR + rubber sole</td></tr>
            <tr><th>Weight</th><td>~180g per shoe (US size 9)</td></tr>
            <tr><th>Drainage</th><td>12+ ports per sole</td></tr>
            <tr><th>Best for</th><td>Beach, paddleboard, kayak, river hike, pool</td></tr>
            <tr><th>Sizing</th><td>True to size · US 5–14 · EU 35–48</td></tr>
            <tr><th>Country of origin</th><td>{{ product.metafields.custom.country_of_origin | default: 'Vietnam' }}</td></tr>
          </tbody>
        </table>
      </div>

      <div class="product-tabs__panel" data-tab-panel="shipping">
        <div class="rte">
          <h3>Shipping</h3>
          <p>Free standard shipping on orders over $79 USD. Most orders to the US, Canada, UK, EU, and Australia arrive within 5–10 business days. Express options available at checkout.</p>
          <h3>Returns</h3>
          <p>60-day try-them-anywhere guarantee. Not happy? Return them for a full refund or exchange — even if worn outside. Free return labels for US orders.</p>
        </div>
      </div>

      <div class="product-tabs__panel" data-tab-panel="care">
        <div class="rte">
          <ol>
            <li>Rinse off sand or salt water after each use.</li>
            <li>Machine wash cold inside a mesh laundry bag, gentle cycle.</li>
            <li>Air dry only — never use a dryer or direct sunlight for extended periods.</li>
            <li>Store dry to prevent odor build-up.</li>
          </ol>
        </div>
      </div>
    </div>

    {%- comment -%} ───── Trust strip (4-up icons, aqua.shoes style) ───── {%- endcomment -%}
    <div class="trust-strip">
      <div class="trust-strip__item">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        <strong>Worldwide shipping</strong>
        <span>Free over $79</span>
      </div>
      <div class="trust-strip__item">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M21 12c0 5.5-4.5 10-10 10S1 17.5 1 12 5.5 2 12 2s10 4.5 10 10z"/></svg>
        <strong>60-day guarantee</strong>
        <span>Satisfied or refunded</span>
      </div>
      <div class="trust-strip__item">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        <strong>Real human support</strong>
        <span>Replies within 1 day</span>
      </div>
      <div class="trust-strip__item">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <strong>Secure checkout</strong>
        <span>SSL · Visa · MC · PayPal</span>
      </div>
    </div>

    {%- comment -%} ───── Variants JSON ───── {%- endcomment -%}
    <script type="application/json" data-product-variants>
      [
        {%- for variant in product.variants -%}
          {
            "id": {{ variant.id }},
            "sku": {{ variant.sku | json }},
            "title": {{ variant.title | json }},
            "available": {{ variant.available }},
            "inventory_quantity": {{ variant.inventory_quantity | default: 0 }},
            "inventory_management": {{ variant.inventory_management | json }},
            "price": {{ variant.price }},
            "compare_at_price": {{ variant.compare_at_price | default: 'null' }},
            "options": {{ variant.options | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    </script>

    <script type="application/json" data-product-meta>
      {
        "id": {{ product.id }},
        "title": {{ product.title | json }},
        "handle": {{ product.handle | json }},
        "url": {{ product.url | json }},
        "image": {{ product.featured_media | image_url: width: 600 | json }}
      }
    </script>
  </div>
</section>

{%- comment -%} ───── Recommendations (powered by /recommendations/products.json) ───── {%- endcomment -%}
{%- if section.settings.show_recommendations -%}
  <section class="section-padding product-recommendations"
           data-product-recommendations
           data-product-id="{{ product.id }}"
           data-limit="{{ section.settings.recommendations_limit }}">
    <div class="page-width">
      <div class="section-heading">
        <span class="eyebrow">You might also like</span>
        <h2>Pair it with</h2>
      </div>
      <div class="product-grid" data-recommendations-grid>
        <div class="product-recommendations__loading">Finding the perfect pair…</div>
      </div>
    </div>
  </section>
{%- endif -%}

{%- comment -%} ───── Recently viewed ───── {%- endcomment -%}
<section class="section-padding recently-viewed" data-recently-viewed hidden>
  <div class="page-width">
    <div class="section-heading">
      <span class="eyebrow">Continue browsing</span>
      <h2>Recently viewed</h2>
    </div>
    <div class="product-grid" data-recently-grid></div>
  </div>
</section>

{%- comment -%} ───── Mobile Sticky Add-to-cart ───── {%- endcomment -%}
<div class="sticky-atc" data-sticky-atc>
  <div class="sticky-atc__inner">
    <div class="sticky-atc__product">
      {%- if product.featured_media -%}
        <img src="{{ product.featured_media | image_url: width: 100 }}" alt="" width="44" height="44">
      {%- endif -%}
      <div class="sticky-atc__info">
        <div class="sticky-atc__title">{{ product.title }}</div>
        <div class="sticky-atc__price" data-sticky-price>{{ current_variant.price | money }}</div>
      </div>
    </div>
    <button type="button" class="btn" data-sticky-atc-btn>Add to cart</button>
  </div>
</div>

{%- comment -%} ───── Size Guide Modal ───── {%- endcomment -%}
<div class="modal" data-size-guide hidden>
  <div class="modal__overlay" data-size-guide-close></div>
  <div class="modal__panel" role="dialog" aria-modal="true" aria-label="Size guide">
    <button type="button" class="modal__close" data-size-guide-close aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h2>Size guide</h2>
    <p style="color:#64748b;margin-bottom:24px;">FirstT fits true to size. If between sizes, size down for a snug swim fit, up for a hike fit.</p>
    <table class="spec-table">
      <thead>
        <tr><th>US</th><th>EU</th><th>UK</th><th>Foot length (cm)</th></tr>
      </thead>
      <tbody>
        <tr><td>5</td><td>35</td><td>3</td><td>22.5</td></tr>
        <tr><td>6</td><td>36</td><td>4</td><td>23.0</td></tr>
        <tr><td>7</td><td>37</td><td>5</td><td>24.0</td></tr>
        <tr><td>8</td><td>38–39</td><td>6</td><td>24.5</td></tr>
        <tr><td>9</td><td>40</td><td>7</td><td>25.5</td></tr>
        <tr><td>10</td><td>41</td><td>8</td><td>26.5</td></tr>
        <tr><td>11</td><td>42</td><td>9</td><td>27.5</td></tr>
        <tr><td>12</td><td>43</td><td>10</td><td>28.0</td></tr>
        <tr><td>13</td><td>44–45</td><td>11</td><td>29.0</td></tr>
        <tr><td>14</td><td>46</td><td>12</td><td>30.0</td></tr>
      </tbody>
    </table>
  </div>
</div>

{% schema %}
{
  "name": "Product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_delivery_estimate",
      "label": "Show estimated delivery date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_recommendations",
      "label": "Show 'You might also like' recommendations",
      "default": true
    },
    {
      "type": "range",
      "id": "recommendations_limit",
      "label": "Recommendations to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    }
  ],
  "blocks": []
}
{% endschema %}
