<section class="collection-header">
  <div class="page-width">
    <h1>{{ blog.title }}</h1>
  </div>
</section>

<section class="collection-body">
  <div class="page-width">
    {%- paginate blog.articles by 12 -%}
      <div class="product-grid">
        {%- for article in blog.articles -%}
          <a href="{{ article.url }}" class="product-card">
            <div class="product-card__media">
              {%- if article.image -%}
                <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.image.alt | escape | default: article.title }}" loading="lazy">
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="product-card__info" style="text-align:left;padding:18px 8px;">
              <div style="font-size:12px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">{{ article.published_at | date: '%b %-d, %Y' }}</div>
              <div class="product-card__title" style="text-align:left;font-size:18px;">{{ article.title }}</div>
              {%- if article.excerpt_or_content != blank -%}
                <p style="font-size:14px;color:#64748b;margin-top:8px;line-height:1.6;">{{ article.excerpt_or_content | strip_html | truncate: 100 }}</p>
              {%- endif -%}
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog",
  "settings": []
}
{% endschema %}
