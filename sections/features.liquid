<section class="section-padding" style="background:{{ section.settings.bg_color | default: '#f8fafc' }}">
  <div class="page-width">
    <div class="section-heading">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p>{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="features-grid">
      {%- for block in section.blocks -%}
        <div class="feature-card" {{ block.shopify_attributes }}>
          <div class="feature-icon">{{ block.settings.icon }}</div>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Features",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Engineered for the elements"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why athletes choose Tidefoot"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Tested in surf, sand, river, and reef. Every detail is designed to keep you moving."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#f8fafc"
    }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "💧"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick-dry knit"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Drains and dries in minutes — no more soggy steps."
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "feature",
        "settings": {
          "icon": "💧",
          "heading": "Quick-Dry Knit",
          "text": "Drains and dries in minutes — no more soggy steps."
        }
      },
      {
        "type": "feature",
        "settings": {
          "icon": "🦶",
          "heading": "Barefoot Feel",
          "text": "Ultra-lightweight design moves with you, not against you."
        }
      },
      {
        "type": "feature",
        "settings": {
          "icon": "⚡",
          "heading": "Anti-Slip Sole",
          "text": "Reinforced rubber grip for wet rocks, decks, and sand."
        }
      },
      {
        "type": "feature",
        "settings": {
          "icon": "🌊",
          "heading": "Reef Protected",
          "text": "Tough outer shields your feet from sharp surfaces."
        }
      }
    ]
  },
  "presets": [
    { "name": "Features" }
  ]
}
{% endschema %}
