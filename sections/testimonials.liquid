<section class="section-padding" style="background:#f0fdfa">
  <div class="page-width">
    <div class="section-heading">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="testimonials-grid">
      {%- for block in section.blocks -%}
        <div class="testimonial" {{ block.shopify_attributes }}>
          <div class="stars">★★★★★</div>
          <p class="testimonial-text">{{ block.settings.text }}</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">{{ block.settings.name | slice: 0, 1 }}</div>
            <div>
              <div class="testimonial-name">{{ block.settings.name }}</div>
              <div class="testimonial-role">{{ block.settings.role }}</div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Loved by 50,000+ customers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real reviews from real adventurers"
    }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Quote",
          "default": "These are the most comfortable water shoes I have ever owned. They dry incredibly fast and the grip is amazing."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Sarah K."
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role / Location",
          "default": "Surfer, San Diego"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "testimonial",
        "settings": {
          "text": "Best water shoes I've ever owned. They're light, they drain instantly, and the grip on wet rocks is unreal. I wear them paddleboarding every weekend.",
          "name": "Sarah K.",
          "role": "Paddleboarder, San Diego"
        }
      },
      {
        "type": "testimonial",
        "settings": {
          "text": "I bought these for a family trip to Hawaii. Three of us wore them daily on lava rock, sand, and in the surf. Zero blisters, zero slipping.",
          "name": "Marcus T.",
          "role": "Verified Buyer"
        }
      },
      {
        "type": "testimonial",
        "settings": {
          "text": "They look way cooler than I expected. I wear them around town too — people always ask where I got them. The teal color is gorgeous.",
          "name": "Emma R.",
          "role": "Yoga Instructor, Miami"
        }
      }
    ]
  },
  "presets": [
    { "name": "Testimonials" }
  ]
}
{% endschema %}
