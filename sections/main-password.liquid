<div class="password-page__card">
  <div class="password-page__logo">{{ shop.name | default: 'AquaStep' }}</div>
  <h1>{{ 'general.password_page.opening_soon' | t }}</h1>
  <p>{{ section.settings.message | default: 'We are setting up something special. Sign up to be the first to know when we launch.' }}</p>

  {%- form 'storefront_password', class: 'password-form' -%}
    {%- if form.errors -%}
      <p style="color:#dc2626;margin-bottom:12px;">Incorrect password</p>
    {%- endif -%}
    <input type="password" name="password" placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}" required>
    <button type="submit" class="btn">{{ 'general.password_page.login_form_submit' | t }}</button>
  {%- endform -%}

  <p style="font-size:13px;color:#94a3b8;margin-top:24px;">{{ 'general.password_page.admin_link_html' | t }}</p>
</div>

{% schema %}
{
  "name": "Password",
  "settings": [
    {
      "type": "textarea",
      "id": "message",
      "label": "Message",
      "default": "We are setting up something special. Sign up to be the first to know when we launch."
    }
  ]
}
{% endschema %}
