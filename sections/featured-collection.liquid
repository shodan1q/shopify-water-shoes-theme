<section class="section-padding">
  <div class="page-width">
    <div class="section-heading">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p>{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- assign products_to_show = section.settings.products_to_show | default: 4 -%}
    {%- assign collection = collections[section.settings.collection] -%}

    <div class="product-grid">
      {%- if collection.products.size > 0 -%}
        {%- for product in collection.products limit: products_to_show -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..products_to_show) -%}
          <a href="#" class="product-card">
            <div class="product-card__media">
              {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="product-card__info">
              <div class="product-card__title">{{ 'onboarding.product_title' | t }}</div>
              <div class="product-card__price">$49.00</div>
            </div>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.view_all -%}
      <div class="text-center mt-8">
        <a href="{{ collection.url | default: '/collections/all' }}" class="btn btn--secondary">
          {{ section.settings.view_all_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Best Sellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made for the water, ready for everything"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Our most-loved styles, engineered with quick-dry fabric and anti-slip soles."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "view_all",
      "label": "Show 'View all' button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Button text",
      "default": "Shop all styles"
    }
  ],
  "presets": [
    { "name": "Featured collection" }
  ]
}
{% endschema %}
