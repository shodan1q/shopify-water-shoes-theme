[
  {
    "name": "theme_info",
    "theme_name": "AquaStep",
    "theme_version": "1.0.0",
    "theme_author": "AquaStep",
    "theme_documentation_url": "https://github.com",
    "theme_support_url": "https://github.com"
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 50,
        "max": 250,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 120
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "32 x 32 px recommended"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary (brand)",
        "default": "#2DD4BF"
      },
      {
        "type": "color",
        "id": "color_primary_dark",
        "label": "Primary dark",
        "default": "#0F766E"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent",
        "default": "#F97316"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_foreground",
        "label": "Foreground (text)",
        "default": "#0F172A"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border",
        "default": "#E2E8F0"
      },
      {
        "type": "color",
        "id": "color_button",
        "label": "Button background",
        "default": "#0F766E"
      },
      {
        "type": "color",
        "id": "color_button_text",
        "label": "Button text",
        "default": "#FFFFFF"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "body_font",
        "label": "Body font",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "Heading font",
        "default": "assistant_n7"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1000,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "label": "Page width",
        "default": 1280
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram",
        "info": "https://instagram.com/yourshop"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook"
      },
      {
        "type": "text",
        "id": "social_tiktok_link",
        "label": "TikTok"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "YouTube"
      },
      {
        "type": "text",
        "id": "social_twitter_link",
        "label": "X (Twitter)"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "Show vendor",
        "default": false
      }
    ]
  }
]
