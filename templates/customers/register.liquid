<section class="auth-page">
  <div class="page-width">
    <div class="auth-card">
      <h1>Create account</h1>
      <p class="auth-subtitle">Join the Tidefoot crew &mdash; get 10% off your first order.</p>

      {%- form 'create_customer', class: 'auth-form' -%}
        {%- if form.errors -%}
          <div class="auth-alert auth-alert--error">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <div class="auth-row">
          <label class="auth-field">
            <span>First name</span>
            <input type="text" name="customer[first_name]" autocomplete="given-name">
          </label>
          <label class="auth-field">
            <span>Last name</span>
            <input type="text" name="customer[last_name]" autocomplete="family-name">
          </label>
        </div>

        <label class="auth-field">
          <span>Email</span>
          <input type="email" name="customer[email]" autocomplete="email" required>
        </label>

        <label class="auth-field">
          <span>Password</span>
          <input type="password" name="customer[password]" autocomplete="new-password" required minlength="5">
        </label>

        <button type="submit" class="btn btn--large">Create account</button>

        <div class="auth-links">
          Already have an account? <a href="{{ routes.account_login_url }}">Sign in</a>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>
