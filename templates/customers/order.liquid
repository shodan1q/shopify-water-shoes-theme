<section class="page-template">
  <div class="page-width">
    <h1>Order {{ order.name }}</h1>
    <p style="text-align:center;color:#64748b;margin-bottom:32px;">Placed on {{ order.created_at | date: '%B %-d, %Y' }}</p>

    <div class="rte">
      <h2>Items</h2>
      <ul style="list-style:none;padding:0;">
        {%- for line_item in order.line_items -%}
          <li style="padding:14px 0;border-bottom:1px solid #e2e8f0;display:flex;justify-content:space-between;">
            <span>{{ line_item.title }} × {{ line_item.quantity }}</span>
            <span>{{ line_item.final_line_price | money }}</span>
          </li>
        {%- endfor -%}
      </ul>
      <p style="margin-top:24px;text-align:right;font-size:20px;font-weight:700;">Total: {{ order.total_price | money }}</p>
      <p style="margin-top:24px;">Status: <strong>{{ order.financial_status_label }}</strong> · {{ order.fulfillment_status_label }}</p>
    </div>

    <div class="text-center mt-8">
      <a href="{{ routes.account_url }}" class="btn btn--secondary">Back to account</a>
    </div>
  </div>
</section>
