<section class="page-template">
  <div class="page-width" style="max-width:480px;">
    <h1 class="text-center">Reset password</h1>
    {%- form 'reset_customer_password' -%}
      {%- if form.errors -%}
        <p style="color:#dc2626;margin-bottom:16px;">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <div style="display:flex;flex-direction:column;gap:14px;margin-top:24px;">
        <input type="password" name="customer[password]" placeholder="New password" required style="padding:14px 18px;border:1.5px solid #e2e8f0;border-radius:8px;">
        <input type="password" name="customer[password_confirmation]" placeholder="Confirm password" required style="padding:14px 18px;border:1.5px solid #e2e8f0;border-radius:8px;">
        <button type="submit" class="btn">Reset password</button>
      </div>
    {%- endform -%}
  </div>
</section>
