<section class="auth-page">
  <div class="page-width">
    <div class="auth-card">
      <h1>Welcome back</h1>
      <p class="auth-subtitle">Sign in to your FirstT account</p>

      {%- form 'customer_login', class: 'auth-form' -%}
        {%- if form.errors -%}
          <div class="auth-alert auth-alert--error">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <label class="auth-field">
          <span>Email</span>
          <input type="email" name="customer[email]" autocomplete="email" required>
        </label>

        <label class="auth-field">
          <span>Password</span>
          <input type="password" name="customer[password]" autocomplete="current-password" required>
        </label>

        <button type="submit" class="btn btn--large">Sign in</button>

        <div class="auth-links">
          <a href="{{ routes.account_recover_url }}">Forgot password?</a>
          <span>·</span>
          <a href="{{ routes.account_register_url }}">Create account</a>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>

{%- form 'recover_customer_password' -%}
  {%- if form.posted_successfully? -%}
    <script>alert('We sent you a password reset email.');</script>
  {%- endif -%}
{%- endform -%}
