<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="{{ settings.color_primary }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <title>{{ shop.name }} &mdash; {{ 'general.password_page.opening_soon' | t }}</title>
    {{ content_for_header }}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    <style>
      :root {
        --color-primary: {{ settings.color_primary }};
        --color-background: {{ settings.color_background }};
        --color-foreground: {{ settings.color_foreground }};
        --color-button: {{ settings.color_button }};
        --color-button-text: {{ settings.color_button_text }};
      }
    </style>
  </head>
  <body class="template-password">
    <main role="main" class="password-page">
      {{ content_for_layout }}
    </main>
  </body>
</html>
